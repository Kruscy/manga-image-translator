{
  "detector": {
    "name": "ctd",
	"detection_size": 2048,
	"text_threshold": 0.5,
    "box_threshold": 0.75,
    "max_candidates": 70,
	"unclip_ratio": 2.3,
    "use_bubble_prefilter": true,
    "bubble_prefilter_confidence": 0.3
  },
  "ocr": {
    "ocr": "48px_ctc",
    "secondary_ocr": "48px",
    "use_mocr_merge": true,
    "ignore_bubble": 0
  },
  "render": {
    "renderer": "manga2eng",
    "alignment": "auto",
    "uppercase": false,
    "lowercase": false,
    "no_hyphenation": true,
    "gimp_font": "CCWildWordsLower-Regular",
    "auto_font_size": true,
    "font_size_offset": -2,
    "min_font_size": 12,
    "max_font_size": 28,
    "max_text_width_ratio": 0.80
  },
  "upscale": {
  "upscaler": "esrgan"
  },
  "inpainter": {
    "name": "lama_large",
    "inpainting_size": 2048,
	"inpainting_precision": "bf16"
  },
  "translator": {
    "translator": "openai",
    "model": "gpt-5-nano",
    "source_lang": "auto",
    "target_lang": "HUN"
  },
   "kernel_size": 3,
   "mask_dilation_offset": 30,
   "models_dir": "C:/Manga/manga-image-translator/models",
   "font_path": "C:/Manga/manga-image-translator/fonts/CCWildWordsLower-Regular.ttf"
}