{
  "_comment_mode": "Torii FULL pipeline: az egész képet elküldi a Torii API-nak (OCR + fordítás + inpainting + renderelés mind Torii csinálja). Ha csak bizonyos részekhez akarod a Torii-t, lásd torii_mixed.json",
  "detector": {
    "name": "ctd",
    "detection_size": 2048,
    "text_threshold": 0.5,
    "box_threshold": 0.75,
    "max_candidates": 70,
    "unclip_ratio": 2.3,
    "use_bubble_prefilter": false,
    "bubble_prefilter_confidence": 0.3
  },
  "ocr": {
    "ocr": "48px_ctc",
    "use_mocr_merge": false,
    "ignore_bubble": 0
  },
  "inpainter": {
    "name": "lama_large",
    "inpainting_size": 2048,
    "inpainting_precision": "bf16"
  },
  "render": {
    "renderer": "manga2eng",
    "alignment": "auto",
    "uppercase": false,
    "lowercase": false,
    "no_hyphenation": true,
    "gimp_font": "CCWildWordsLower-Regular",
    "font_size_offset": -2,
    "min_font_size": 12,
    "max_font_size": 28,
    "max_text_width_ratio": 0.80
  },
  "upscale": {
    "upscaler": "esrgan"
  },
  "translator": {
    "translator": "torii",
    "target_lang": "HUN",
    "torii_model": "gemini-3-flash",
    "torii_font": "wildwords",
    "torii_text_align": "center",
    "torii_stroke_disabled": false,
    "torii_min_font_size": 24
  },
  "kernel_size": 3,
  "mask_dilation_offset": 30,
  "models_dir": "C:/Manga/manga-image-translator/models",
  "font_path": "C:/Manga/manga-image-translator/fonts/CCWildWordsLower-Regular.ttf"
}
